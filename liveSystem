from ultralytics import YOLO
import os
import cv2 as cv
import numpy as np
from collections import Counter
import sys
print(sys.executable)

# ===================== Define Ball Colours and Values =====================
ballColours = {
    "red" : (5, 150, 255),
    "shadedRed" : (178, 226, 131),
    "yellow" : (30, 160, 255),
    "green" : (85, 250, 222),
    "brown" : (15, 165, 165),
    "blue" : (107, 255, 99),
    "pink" : (9, 90, 236),
    "black" : (73, 102, 65),
    "white" : (44, 15, 255),
    "shadedWhite" : (41, 133, 173),
    "shadedBlack" : (54, 149, 60)
}
ballValues = {
    "red" : 1,
    "yellow" : 2,
    "green" : 3,
    "brown" : 4,
    "blue" : 5,
    "pink" : 6,
    "black" : 7,
}

# ===================== The functions to determine ball colours =====================
def findColour(center, radius, img):
    mask = np.zeros(img.shape[:2], dtype=np.uint8) #Create a mask of the circle around where the ball was detected
    cv.circle(mask, center, int(radius*0.5), 255, -1)
    colour = cv.mean(img, mask=mask) #Average the colour of the whole circle
    print(center)
    return colour #Return this colour
def findClosestColour(colour, ballColours):
    bgrPixel = np.uint8([[colour]]) #Get the detected colour as a single pixel
    hsvPixel = cv.cvtColor(bgrPixel, cv.COLOR_BGR2HSV) #Convert the pixel to HSV
    hsv = hsvPixel[0][0]
    print(hsv)

    #Calculate the closest ball colour that matches this pixel
    bestDistance = 99999
    bestColour = None

    for name, ballColour in ballColours.items(): #Loop through every ball colour
        dh = min(abs(int(hsv[0]) - ballColour[0]), 180 - abs(int(hsv[0]) - ballColour[0])) #Find the distance between the hues
        ds = abs(int(hsv[1]) - ballColour[1]) #Find the distance between saturations
        dv = abs(int(hsv[2]) - ballColour[2]) #Find the distance between values
        colourDistance = 8*dh + ds + dv #Get the total distance over the 3 values (heavilly weighted towards hue)
        if colourDistance < bestDistance: #If this distance is better than the current one:
            bestDistance = colourDistance #Replace the best distance with the current one
            bestColour = name
    
    #If the best colour is the shaded version of an existing colour, set it to that colour
    if bestColour == "shadedRed": bestColour = "red"
    elif bestColour == "shadedBlack": bestColour = "black"
    elif bestColour == "shadedWhite": bestColour = "white"
    print(bestColour)
    return bestColour #Return the best colour

#base_dir = os.path.dirname(os.path.abspath(__file__))

# ===================== Initial Declarations =====================
model = YOLO("yolo26m.yaml") #Load the medium version of YOLOv26
model = YOLO("yolo26m.pt")

#Get the system webcam information and use this for the video capture device
s = 0
if len(sys.argv) > 1:
    s = sys.argv[1]
    print(sys.argv)

cap = cv.VideoCapture(1)

#Define the base values for neccesary variables
previousWhite, roundedCoordinates = [0, 0], [0, 0]
previousBalls = []
previousColours = [Counter() for x in range(10)]
playerScores = [0, 0]
stopCounter = 0
moveCounter = 0
moving, currentPlayer = False, False
positionRounding = 2
switchCounter = -1
annotation = ""
alive = True

# ===================== Main Sequence =====================
while alive: #Run while the system is active
    ret, frame = cap.read() #Close if there is no next frame found
    if not ret:
        break

    results = model(frame, device=0) #Get the detected objects from YOLO's analysis of the frame
    annotated = frame.copy() #Copy the frame into an annotated frame to be edited on

    if not moving: #If the white ball is not moving,
        for i in range(9): #Shift the previous detected colours along the list
            previousColours[i] = previousColours[i+1]
    previousColours[9] = Counter() #Reset the current detected balls

    # ===================== Ball Detection ===================== 
    if results[0] is not None: #If YOLO has detected any objects:
        for ball in results[0].boxes: #Loop through each detection
            x, y, w, h = ball.xywh[0].tolist() #Get the x and y coordinate and the width and height of the detected object
            id = model.names[int(ball.cls[0])] #Get the label of the object
            
            if id != "sports ball": #If the object is not a ball,
                continue #Skip to the next object

            colour = findColour((int(x), int(y)), w/2, frame) #Find the average colour of the ball
            ballColour = findClosestColour(colour, ballColours) #Find the closest snooker ball it could then be
            cv.putText(annotated, ballColour, (int(x) - 10, int(y) - 20), cv.FONT_HERSHEY_COMPLEX, 0.6, (255, 255, 255), 2) #Label the ball with this colour

            if ballColour == "white": #If the white has been found:
                roundedCoordinates = [x,y] #Update the current coordinates of the white ball

            previousColours[9][ballColour] += 1 #Add this ball to the current list of colours
            x1, y1, x2, y2 = ball.xyxy[0].tolist() #Get the top right and bottom left coordinates of the ball
            print(x1)
            annotated = cv.rectangle(annotated, (int(x1), int(y1)), (int(x2), int(y2)), (165, 0, 255)) #Use the coordinates to draw a bounding box over the ball
    
    # ===================== Pot Detection ===================== 
    if previousWhite[0] > roundedCoordinates[0] + positionRounding or previousWhite[0] < roundedCoordinates[0] - positionRounding or previousWhite[1] > roundedCoordinates[1] + positionRounding or previousWhite[1] < roundedCoordinates[1] - positionRounding: #If the white ball has moved more than the alloted distance since its last detection:
        if moveCounter > 1: #If the white has moved more than once in the alloted period of time:
            stopCounter = 0 #Reset the stopped counter
            moving = True #Set the flag for the white ball moving
            annotation = "Moving" 
            previousBalls = [] #Reset the list for average ball locations after a shot
        else:
            moveCounter += 1 #If the white has only moved once in the alloted period of time:
            moving = False #Set the moving flag to false
    else: #Else, the white is currently thought to be stationary
        if stopCounter < 20: #If the white has moved in the past 20 frames:
            stopCounter += 1 #Add one to the count of stationary frames
            moving = True #Set the moving flag to true
            previousBalls.append(previousColours[9]) #Add the current detected balls to the previous balls list
            annotation = previousColours[9]
        elif stopCounter == 20: #Else if the ball has just been deemed to have stopped:
            moveCounter = 0 #Reset the count of moving frames
            stopCounter += 1 #Add one to the count of stationary frames
            moving = False #Set the moving flag to false

            ballsWhenMoving = Counter() #Create a new counter for average ball detections after the white moved
            ballsWhenStopped = Counter() #Create a new counter for average ball detections before the white moved
            for counter in previousBalls: #Loop through every moving ball detection index
                ballsWhenMoving += counter #Add the count to the total ballsWhenMoving counter
            for colour in ballsWhenMoving: #Loop through every colour in the counter
                ballsWhenMoving[colour] = round(ballsWhenMoving[colour]/20) #Average the detections out
            for x in range(9): #Loop through every stationary ball detection but the most recent
                ballsWhenStopped += previousColours[x] #Add the count to the total ballsWhenStopped counter
            for colour in ballsWhenStopped: #Loop through every colour in the counter
                ballsWhenStopped[colour] = round(ballsWhenStopped[colour]/9) #Average the detections out
            pottedBall = list((ballsWhenStopped - ballsWhenMoving).elements()) #Create a list for every ball that was in frame before the white moved but not after

            if pottedBall: #If a ball was potted:
                if "white" in pottedBall or "shadedWhite" in pottedBall: #If the ball was the white:
                    annotation = "pot miss"
                    currentPlayer = not currentPlayer #Switch the current player at the table
                    playerScores[int(currentPlayer)] += 4 #Add 4 points to the new player
                else: #Else, the player has potted a ball:
                    playerScores[int(currentPlayer)] += ballValues[pottedBall[0]] #Add the value of the ball potted to the player's score
                annotation = str(playerScores)
            else: #Else, the player has misseda ball, so switch to the other player
                currentPlayer = not currentPlayer
                annotation = "pot miss"
                switchCounter += 1
        else: #Else, Continue adding to the stop counter
            stopCounter += 1
            moving = False
            annotation = "not moving"
    
    previousWhite = roundedCoordinates# Replace the previous white position with the current white position

    # ===================== Drawing to the Screen =====================
    #annotated = cv.putText(annotated, str(annotation), (40, 40), cv.FONT_HERSHEY_COMPLEX, 1, (255, 255, 255), 2)

    annotated = cv.copyMakeBorder(annotated, 0, 60, 0, 0, borderType=cv.BORDER_CONSTANT, value=(0, 0, 0)) #Make a black border of height 60px at the bottom of the screen
    height, width, channels = annotated.shape #Get the width and height of the frame
    annotated = cv.putText(annotated, ("Player 1"), (40, height-20), cv.FONT_HERSHEY_COMPLEX, 1, (255, 255, 255), 2) #Add text for player 1's name
    annotated = cv.putText(annotated, ("Player 2"), (width-300, height-20), cv.FONT_HERSHEY_COMPLEX, 1, (255, 255, 255), 2) #Add text for player 2's name
    annotated = cv.rectangle(annotated, (int((width/2)-100), height-60), (int((width/2)+100), height), (255, 255, 255), -1) #Add The box that contains the players' scores
    annotated = cv.line(annotated, (int(width/2), height-10), (int(width/2), height-50), (0, 0, 0), 1) #Add a line to seperate the 2 scores
    annotated = cv.putText(annotated, str(playerScores[0]), (int((width/2)-60), height-20), cv.FONT_HERSHEY_COMPLEX, 1, (0, 0, 0), 2) #Add text for the first player's score
    annotated = cv.putText(annotated, str(playerScores[1]), (int((width/2)+30), height-20), cv.FONT_HERSHEY_COMPLEX, 1, (0, 0, 0), 2) #Add text for the second player's score
    if not currentPlayer: #If the first player is at the table:
        annotated = cv.circle(annotated, (int((width/2)-180), height-30), 10, (255, 255, 255), -1) #Display a circle to show that this player is at the table
    else: #Else, the second player is at the table:
        annotated = cv.circle(annotated, (int((width/2)+180), height-30), 10, (255, 255, 255), -1) #Display a circle to show that this player is at the table

    cv.imshow("Detections", annotated)#Display the annotated frame to the screen

    if cv.waitKey(1) == ord('q'): #If the 'q' key is pressed, stop the program
        break
    if cv.waitKey(1) == ord('r'): #If the 'r' key is pressed, reset the scores
        playerScores = [0,0]
#If the loop has been terminated,
cap.release() #Close the video capture
cv.destroyAllWindows() #Close the frame view window
